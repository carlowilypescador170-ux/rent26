<% layout('layouts/boilerplate') %>
<% pageTitle = 'Audit Logs' %>

<div class="page-header">
  <div class="container-fluid px-4">
    <h1><i class="bi bi-journal-text me-2" style="font-size:28px;"></i>System Audit Log</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/superadmin/dashboard" style="color:rgba(255,255,255,0.6);">Super Admin</a></li>
        <li class="breadcrumb-item active">Audit Logs</li>
      </ol>
    </nav>
  </div>
</div>

<div class="container-fluid px-4 py-4">

  <!-- Filters -->
  <div class="jm-card mb-4">
    <div class="jm-card-body">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Action</label>
          <select name="action" class="form-select">
            <option value="">All Actions</option>
            <% const actions = ['USER_REGISTER','USER_LOGIN','USER_LOGOUT','PASSWORD_CHANGE','RENTAL_CREATE','RENTAL_APPROVE','RENTAL_REJECT','RENTAL_CANCEL','RENTAL_COMPLETE','RENTAL_EXTEND','ITEM_CREATE','ITEM_UPDATE','ITEM_DELETE','USER_UPDATE','USER_DEACTIVATE','USER_ROLE_CHANGE'] %>
            <% actions.forEach(a => { %>
              <option value="<%= a %>" <%= currentAction === a ? 'selected' : '' %>><%= a.replace(/_/g,' ') %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Role</label>
          <select name="role" class="form-select">
            <option value="">All Roles</option>
            <option value="user"       <%= currentRole === 'user'       ? 'selected' : '' %>>User</option>
            <option value="admin"      <%= currentRole === 'admin'      ? 'selected' : '' %>>Admin</option>
            <option value="superadmin" <%= currentRole === 'superadmin' ? 'selected' : '' %>>Super Admin</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Status</label>
          <select name="status" class="form-select">
            <option value="">All</option>
            <option value="success" <%= currentLogStatus === 'success' ? 'selected' : '' %>>Success</option>
            <option value="failed"  <%= currentLogStatus === 'failed'  ? 'selected' : '' %>>Failed</option>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-maroon w-100"><i class="bi bi-filter me-2"></i>Filter</button>
        </div>
      </form>
    </div>
  </div>

  <div class="jm-card">
    <div class="jm-card-body p-0">
      <div class="table-responsive">
        <table class="jm-table">
          <thead>
            <tr>
              <th>Timestamp</th>
              <th>Performed By</th>
              <th>Role</th>
              <th>Action</th>
              <th>Target</th>
              <th>IP</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (logs && logs.length > 0) { %>
              <% logs.forEach(log => { %>
                <tr>
                  <td style="font-size:12px;white-space:nowrap;color:var(--text-muted);">
                    <%= new Date(log.createdAt).toLocaleString('en-PH',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                  </td>
                  <td>
                    <div style="font-size:13px;font-weight:500;"><%= log.performedBy ? log.performedBy.fullName : 'System' %></div>
                    <% if (log.performedBy) { %>
                      <div class="font-mono" style="font-size:11px;color:var(--text-muted);">@<%= log.performedBy.username %></div>
                    <% } %>
                  </td>
                  <td>
                    <span class="font-mono" style="font-size:11px;background:var(--maroon-pale);color:var(--maroon);padding:2px 8px;border-radius:4px;text-transform:uppercase;"><%= log.role %></span>
                  </td>
                  <td>
                    <span class="font-mono" style="font-size:12px;"><%= log.action %></span>
                    <% if (log.description) { %>
                      <div style="font-size:11px;color:var(--text-muted);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= log.description %>"><%= log.description %></div>
                    <% } %>
                  </td>
                  <td style="font-size:12px;color:var(--text-muted);">
                    <%= log.targetCollection || '—' %>
                  </td>
                  <td class="font-mono" style="font-size:11px;color:var(--text-muted);"><%= log.ipAddress || '—' %></td>
                  <td>
                    <span class="status-badge <%= log.status === 'success' ? 'status-approved' : 'status-cancelled' %>"><%= log.status %></span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="7" class="text-center py-4" style="color:var(--text-muted);">No audit logs found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <nav class="mt-3">
      <ul class="pagination justify-content-center">
        <% for (let p = 1; p <= totalPages; p++) { %>
          <li class="page-item <%= p === currentPage ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&action=<%= currentAction||'' %>&role=<%= currentRole||'' %>"
              style="<%= p === currentPage ? 'background:var(--maroon);border-color:var(--maroon);' : 'color:var(--maroon);' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>
