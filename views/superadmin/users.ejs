<% layout('layouts/boilerplate') %>
<% pageTitle = 'All Users — Super Admin' %>

<div class="page-header">
  <div class="container-fluid px-4">
    <h1><i class="bi bi-people me-2" style="font-size:28px;"></i>All Users</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/superadmin/dashboard" style="color:rgba(255,255,255,0.6);">Super Admin</a></li>
        <li class="breadcrumb-item active">Users</li>
      </ol>
    </nav>
  </div>
</div>

<div class="container-fluid px-4 py-4">

  <!-- Filters -->
  <div class="jm-card mb-4">
    <div class="jm-card-body">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="form-label">Search</label>
          <input type="text" name="search" class="form-control" placeholder="Name, username or email..." value="<%= search || '' %>" />
        </div>
        <div class="col-md-3">
          <label class="form-label">Role</label>
          <select name="role" class="form-select">
            <option value="">All Roles</option>
            <option value="user"       <%= filterRole === 'user'       ? 'selected' : '' %>>Customer</option>
            <option value="admin"      <%= filterRole === 'admin'      ? 'selected' : '' %>>Admin</option>
            <option value="superadmin" <%= filterRole === 'superadmin' ? 'selected' : '' %>>Super Admin</option>
          </select>
        </div>
        <div class="col-md-5">
          <button type="submit" class="btn btn-maroon w-100"><i class="bi bi-search me-2"></i>Search</button>
        </div>
      </form>
    </div>
  </div>

  <div class="jm-card">
    <div class="jm-card-body p-0">
      <div class="table-responsive">
        <table class="jm-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Contact</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Last Login</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (users && users.length > 0) { %>
              <% users.forEach(u => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,<%= u.role==='superadmin' ? 'var(--maroon-dk),var(--gold)' : u.role==='admin' ? 'var(--maroon),var(--maroon-lt)' : 'var(--maroon-lt),#D48A9E' %>);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;flex-shrink:0;">
                        <%= u.fullName.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <div style="font-size:14px;font-weight:500;"><%= u.fullName %></div>
                        <div class="font-mono" style="font-size:11px;color:var(--text-muted);">@<%= u.username %></div>
                      </div>
                    </div>
                  </td>
                  <td style="font-size:13px;">
                    <div><%= u.email %></div>
                    <div style="color:var(--text-muted)"><%= u.phoneNumber %></div>
                  </td>
                  <td>
                    <span class="font-mono" style="font-size:11px;text-transform:uppercase;background:<%= u.role==='superadmin' ? 'rgba(78,15,28,0.1)' : 'var(--maroon-pale)' %>;color:var(--maroon);padding:3px 8px;border-radius:4px;">
                      <%= u.role %>
                    </span>
                  </td>
                  <td style="font-size:13px;color:var(--text-muted);"><%= new Date(u.createdAt).toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'}) %></td>
                  <td style="font-size:12px;color:var(--text-muted);">
                    <%= u.lastLogin ? new Date(u.lastLogin).toLocaleDateString('en-PH',{month:'short',day:'numeric'}) : 'Never' %>
                  </td>
                  <td><span class="status-badge <%= u.isActive ? 'status-approved' : 'status-cancelled' %>"><%= u.isActive ? 'active' : 'inactive' %></span></td>
                  <td>
                    <div class="d-flex gap-1 flex-wrap">
                      <!-- Role change -->
                      <% if (u.role !== 'superadmin') { %>
                        <button class="btn btn-sm" style="font-size:11px;background:var(--maroon-pale);color:var(--maroon);padding:3px 8px;"
                          data-bs-toggle="modal" data-bs-target="#roleModal"
                          data-id="<%= u._id %>" data-name="<%= u.fullName %>" data-role="<%= u.role %>">
                          <i class="bi bi-person-gear me-1"></i>Role
                        </button>
                      <% } %>
                      <!-- Toggle active -->
                      <form action="/superadmin/users/<%= u._id %>/toggle" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-sm" style="font-size:11px;background:<%= u.isActive ? '#FEE2E2' : '#D1FAE5' %>;color:<%= u.isActive ? '#991B1B' : '#065F46' %>;">
                          <i class="bi bi-<%= u.isActive ? 'person-x' : 'person-check' %>"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="7" class="text-center py-4" style="color:var(--text-muted);">No users found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <nav class="mt-3">
      <ul class="pagination justify-content-center">
        <% for (let p = 1; p <= totalPages; p++) { %>
          <li class="page-item <%= p === currentPage ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&search=<%= search||'' %>&role=<%= filterRole||'' %>"
              style="<%= p === currentPage ? 'background:var(--maroon);border-color:var(--maroon);' : 'color:var(--maroon);' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>

<!-- Role Change Modal -->
<div class="modal fade" id="roleModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:16px;overflow:hidden;">
      <div class="modal-header" style="background:linear-gradient(135deg,var(--maroon-dk),var(--maroon));color:white;border:none;">
        <h5 class="modal-title font-display"><i class="bi bi-person-gear me-2"></i>Change User Role</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="roleForm" method="POST">
        <div class="modal-body p-4">
          <p style="font-size:14px;color:var(--text-muted);">Changing role for: <strong id="roleUserName" style="color:var(--maroon);"></strong></p>
          <label class="form-label">New Role</label>
          <select name="role" id="roleSelect" class="form-select" required>
            <option value="user">Customer (user)</option>
            <option value="admin">Admin</option>
          </select>
          <div class="mt-3 p-2 rounded-2" style="background:#FEF3C7;font-size:12px;color:#92400E;border:1px solid #FCD34D;">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Role changes are logged in the audit trail and take effect immediately.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-maroon" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-maroon"><i class="bi bi-check-circle me-2"></i>Apply Change</button>
        </div>
      </form>
    </div>
  </div>
</div>

<% extraScripts = `
<script>
  document.getElementById('roleModal').addEventListener('show.bs.modal', function(e) {
    const btn = e.relatedTarget;
    document.getElementById('roleUserName').textContent = btn.dataset.name;
    document.getElementById('roleSelect').value = btn.dataset.role;
    document.getElementById('roleForm').action = '/superadmin/users/' + btn.dataset.id + '/role';
  });
</script>
` %>
