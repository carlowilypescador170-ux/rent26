<% layout('layouts/boilerplate') %>
<% pageTitle = 'Admin Dashboard' %>

<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h1><i class="bi bi-speedometer2 me-2" style="font-size:28px;"></i>Admin Dashboard</h1>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb"><li class="breadcrumb-item active">Dashboard</li></ol>
        </nav>
      </div>
      <div style="font-size:13px;color:rgba(255,255,255,0.65);">
        <i class="bi bi-calendar3 me-1"></i><%= new Date().toLocaleDateString('en-PH',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) %>
      </div>
    </div>
  </div>
</div>

<div class="container-fluid py-4 px-4">

  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3 col-xl-2">
      <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div class="stat-value"><%= stats.totalUsers || 0 %></div>
        <div class="stat-label">Customers</div>
      </div>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <div class="stat-card">
        <div class="stat-icon" style="background:linear-gradient(135deg,#D69E2E,#ECC94B);"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-value" style="color:#D69E2E;"><%= stats.pending || 0 %></div>
        <div class="stat-label">Pending</div>
      </div>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <div class="stat-card">
        <div class="stat-icon" style="background:linear-gradient(135deg,#2B6CB0,#4299E1);"><i class="bi bi-play-circle-fill"></i></div>
        <div class="stat-value" style="color:#2B6CB0;"><%= stats.active || 0 %></div>
        <div class="stat-label">Active</div>
      </div>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <div class="stat-card">
        <div class="stat-icon" style="background:linear-gradient(135deg,#276749,#48BB78);"><i class="bi bi-check-circle-fill"></i></div>
        <div class="stat-value" style="color:#276749;"><%= stats.completed || 0 %></div>
        <div class="stat-label">Completed</div>
      </div>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <div class="stat-card">
        <div class="stat-icon" style="background:linear-gradient(135deg,var(--gold),var(--gold-lt));"><i class="bi bi-cash-coin"></i></div>
        <div class="stat-value" style="color:var(--gold);font-size:24px;">₱<%= ((stats.totalRevenue || 0)/1000).toFixed(1) %>k</div>
        <div class="stat-label">Revenue</div>
      </div>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <div class="stat-card">
        <div class="stat-icon" style="background:linear-gradient(135deg,#553C9A,#805AD5);"><i class="bi bi-box-fill"></i></div>
        <div class="stat-value" style="color:#553C9A;"><%= stats.totalItems || 0 %></div>
        <div class="stat-label">Item Types</div>
      </div>
    </div>
  </div>

  <div class="row g-4">

    <!-- Pending Rentals -->
    <div class="col-xl-8">
      <div class="jm-card">
        <div class="jm-card-header d-flex justify-content-between align-items-center">
          <h5><i class="bi bi-hourglass me-2"></i>Pending Approvals
            <% if (stats.pending > 0) { %><span class="badge ms-2" style="background:var(--gold);color:var(--maroon-dk);font-family:'DM Mono',monospace;"><%= stats.pending %></span><% } %>
          </h5>
          <a href="/admin/rentals?status=pending" class="btn btn-sm btn-outline-light" style="font-size:12px;">View All</a>
        </div>
        <div class="jm-card-body p-0">
          <% if (pendingRentals && pendingRentals.length > 0) { %>
            <div class="table-responsive">
              <table class="jm-table">
                <thead><tr><th>Ref #</th><th>Customer</th><th>Items</th><th>Dates</th><th>Total</th><th>Actions</th></tr></thead>
                <tbody>
                  <% pendingRentals.forEach(r => { %>
                    <tr>
                      <td><span class="ref-num"><%= r.referenceNumber %></span></td>
                      <td>
                        <div style="font-size:14px;font-weight:500;"><%= r.customer.fullName %></div>
                        <div style="font-size:11.5px;color:var(--text-muted);"><%= r.customer.phoneNumber %></div>
                      </td>
                      <td style="font-size:13px;"><%= r.items.map(i => i.quantity + '× ' + i.itemType.replace('_',' ')).join(', ') %></td>
                      <td style="font-size:12px;color:var(--text-muted);">
                        <%= new Date(r.rentalStartDate).toLocaleDateString('en-PH',{month:'short',day:'numeric'}) %> –
                        <%= new Date(r.rentalEndDate).toLocaleDateString('en-PH',{month:'short',day:'numeric'}) %>
                      </td>
                      <td style="font-weight:700;color:var(--maroon);">₱<%= r.totalCost.toLocaleString() %></td>
                      <td>
                        <div class="d-flex gap-1">
                          <form action="/admin/rentals/<%= r._id %>/approve" method="POST">
                            <button type="submit" class="btn btn-sm" style="background:#D1FAE5;color:#065F46;font-size:11px;padding:4px 10px;" title="Approve">
                              <i class="bi bi-check-lg"></i>
                            </button>
                          </form>
                          <a href="/admin/rentals/<%= r._id %>" class="btn btn-sm btn-outline-maroon" style="font-size:11px;padding:4px 10px;">View</a>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-4" style="color:var(--text-muted);">
              <i class="bi bi-check-circle" style="font-size:32px;opacity:0.3;display:block;margin-bottom:8px;"></i>
              <p style="font-size:14px;margin:0;">No pending approvals. All caught up!</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Quick Links + Chart -->
    <div class="col-xl-4">

      <!-- Quick Links -->
      <div class="jm-card mb-4">
        <div class="jm-card-header"><h5><i class="bi bi-lightning me-2"></i>Quick Actions</h5></div>
        <div class="jm-card-body d-grid gap-2">
          <a href="/admin/rentals" class="btn btn-outline-maroon text-start"><i class="bi bi-calendar-check me-2"></i>All Rentals</a>
          <a href="/admin/items" class="btn btn-outline-maroon text-start"><i class="bi bi-box me-2"></i>Manage Items</a>
          <a href="/admin/items/new" class="btn btn-outline-maroon text-start"><i class="bi bi-plus-square me-2"></i>Add New Item</a>
          <a href="/admin/users" class="btn btn-outline-maroon text-start"><i class="bi bi-people me-2"></i>View Customers</a>
        </div>
      </div>

      <!-- Rental by Status Breakdown -->
      <div class="jm-card">
        <div class="jm-card-header"><h5><i class="bi bi-bar-chart me-2"></i>Rental Overview</h5></div>
        <div class="jm-card-body">
          <canvas id="statusChart" height="200"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent all rentals -->
  <div class="jm-card mt-4">
    <div class="jm-card-header d-flex justify-content-between align-items-center">
      <h5><i class="bi bi-clock-history me-2"></i>Recent Rental Activity</h5>
      <a href="/admin/rentals" class="btn btn-sm btn-outline-light" style="font-size:12px;">View All</a>
    </div>
    <div class="jm-card-body p-0">
      <div class="table-responsive">
        <table class="jm-table">
          <thead><tr><th>Ref #</th><th>Customer</th><th>Items</th><th>Dates</th><th>Total</th><th>Payment</th><th>Status</th></tr></thead>
          <tbody>
            <% if (recentRentals && recentRentals.length > 0) { %>
              <% recentRentals.forEach(r => { %>
                <tr onclick="window.location='/admin/rentals/<%= r._id %>'" style="cursor:pointer;">
                  <td><span class="ref-num"><%= r.referenceNumber %></span></td>
                  <td style="font-size:14px;"><%= r.customer.fullName %></td>
                  <td style="font-size:13px;color:var(--text-muted);"><%= r.items.length %> type(s)</td>
                  <td style="font-size:12px;color:var(--text-muted);"><%= new Date(r.rentalStartDate).toLocaleDateString('en-PH',{month:'short',day:'numeric'}) %></td>
                  <td style="font-weight:700;color:var(--maroon);">₱<%= r.totalCost.toLocaleString() %></td>
                  <td><span class="status-badge <%= r.paymentStatus==='paid'?'status-approved':'status-pending' %>"><%= r.paymentStatus %></span></td>
                  <td><span class="status-badge status-<%= r.status %>"><%= r.status %></span></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="7" class="text-center py-4" style="color:var(--text-muted);">No rentals yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<% extraScripts = `
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  const ctx = document.getElementById('statusChart');
  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Pending', 'Approved', 'Active', 'Completed', 'Cancelled'],
      datasets: [{
        data: [
          ${stats.pending || 0},
          ${stats.approved || 0},
          ${stats.active || 0},
          ${stats.completed || 0},
          ${stats.cancelled || 0}
        ],
        backgroundColor: ['#F59E0B','#34D399','#60A5FA','#9CA3AF','#F87171'],
        borderWidth: 0,
        hoverOffset: 6
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 12 }, padding: 12 } }
      }
    }
  });
</script>
` %>
