<% layout('layouts/boilerplate') %>
<% pageTitle = 'Notifications' %>

<div class="page-header">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1><i class="bi bi-bell me-2" style="font-size:28px;"></i>Notifications</h1>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/user/dashboard" style="color:rgba(255,255,255,0.6);">Dashboard</a></li>
            <li class="breadcrumb-item active">Notifications</li>
          </ol>
        </nav>
      </div>
      <% if (notifications.some(n => !n.isRead)) { %>
        <form action="/notifications/read-all" method="POST">
          <button type="submit" class="btn btn-gold btn-sm">
            <i class="bi bi-check2-all me-2"></i>Mark All as Read
          </button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<div class="container py-4" style="max-width:720px;">
  <% if (notifications && notifications.length > 0) { %>
    <div class="jm-card">
      <% notifications.forEach((n, i) => { %>
        <div class="d-flex gap-3 align-items-start p-4"
          style="border-bottom:<%= i < notifications.length-1 ? '1px solid var(--border-lt)' : 'none' %>;<%= !n.isRead ? 'background:var(--maroon-pale);' : '' %>"
          id="notif-<%= n._id %>">

          <div style="width:44px;height:44px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px;
            background:<%= n.type.includes('APPROVED') ? '#D1FAE5' : n.type.includes('REJECTED') || n.type.includes('CANCELLED') ? '#FEE2E2' : n.type.includes('REMINDER') ? '#FEF3C7' : 'var(--maroon-pale)' %>;">
            <% if (n.type.includes('APPROVED'))  { %><i class="bi bi-check-circle-fill" style="color:#065F46;"></i>
            <% } else if (n.type.includes('REJECTED') || n.type.includes('CANCELLED')) { %><i class="bi bi-x-circle-fill" style="color:#991B1B;"></i>
            <% } else if (n.type.includes('REMINDER')) { %><i class="bi bi-alarm-fill" style="color:#92400E;"></i>
            <% } else if (n.type.includes('EXTENDED'))  { %><i class="bi bi-calendar-plus-fill" style="color:var(--maroon);"></i>
            <% } else { %><i class="bi bi-bell-fill" style="color:var(--maroon);"></i>
            <% } %>
          </div>

          <div style="flex:1;">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-1">
              <div style="font-weight:<%= n.isRead ? '400' : '700' %>;font-size:15px;color:var(--text-dark);">
                <%= n.title %>
                <% if (!n.isRead) { %><span class="badge ms-1" style="background:var(--gold);color:var(--maroon-dk);font-size:9px;font-family:'DM Mono',monospace;">NEW</span><% } %>
              </div>
              <div style="font-size:11px;color:var(--text-muted);white-space:nowrap;font-family:'DM Mono',monospace;">
                <%= new Date(n.createdAt).toLocaleString('en-PH',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %>
              </div>
            </div>
            <p style="font-size:14px;color:var(--text-muted);margin:4px 0 0;line-height:1.6;"><%= n.message %></p>
            <% if (n.relatedRental) { %>
              <a href="/user/rentals/<%= n.relatedRental._id %>"
                style="font-size:12px;color:var(--maroon);font-weight:700;text-decoration:none;margin-top:6px;display:inline-block;">
                <i class="bi bi-box-arrow-up-right me-1"></i>View Rental <%= n.relatedRental.referenceNumber %>
              </a>
            <% } %>
          </div>

          <% if (!n.isRead) { %>
            <button onclick="markRead('<%= n._id %>')" title="Mark as read"
              style="background:none;border:none;color:var(--text-muted);cursor:pointer;padding:4px;flex-shrink:0;">
              <i class="bi bi-circle-fill" style="font-size:10px;color:var(--maroon);"></i>
            </button>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <div style="width:80px;height:80px;border-radius:50%;background:var(--maroon-pale);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
        <i class="bi bi-bell-slash" style="font-size:36px;color:var(--maroon);opacity:0.4;"></i>
      </div>
      <h4 class="font-display" style="color:var(--maroon);">No notifications yet</h4>
      <p style="color:var(--text-muted);font-size:14px;">You'll be notified here when your rental is approved, rejected, or updated.</p>
      <a href="/user/rentals" class="btn btn-maroon mt-1"><i class="bi bi-box-seam me-2"></i>My Rentals</a>
    </div>
  <% } %>
</div>

<% extraScripts = `
<script>
  async function markRead(id) {
    try {
      await fetch('/notifications/' + id + '/read', { method: 'POST' });
      const el = document.getElementById('notif-' + id);
      if (el) {
        el.style.background = '';
        const badge = el.querySelector('.badge');
        if (badge) badge.remove();
        const btn = el.querySelector('button[onclick]');
        if (btn) btn.remove();
      }
      // Update navbar badge
      const navBadge = document.querySelector('.nav-badge');
      if (navBadge) {
        const count = parseInt(navBadge.textContent) - 1;
        if (count <= 0) navBadge.remove();
        else navBadge.textContent = count;
      }
    } catch(e) {}
  }
</script>
` %>
