<% layout('layouts/boilerplate') %>
<% pageTitle = 'New Rental' %>

<div class="page-header" style="background: var(--maroon); color: white; padding: 2rem 0; margin-bottom: 2rem;">
  <div class="container">
    <h1><i class="bi bi-plus-circle me-2"></i>New Rental</h1>
    <p class="mb-0" style="opacity: 0.8;">Fill out the form below to request a new rental.</p>
  </div>
</div>

<div class="container py-4">
  <form id="rentalForm" action="/user/rentals" method="POST">
    <div id="hiddenInputsContainer"></div>

    <div class="row g-4">
      <div class="col-lg-8">
        
        <div class="jm-card mb-4 p-4 shadow-sm" style="background: white; border-radius: 15px;">
          <h5 class="mb-4" style="color: var(--maroon); font-weight: 700;">
            <i class="bi bi-1-circle-fill me-2"></i>Step 1 — Select Items
          </h5>
          <div class="row g-3">
            <% items.forEach(function(item) { %>
              <div class="col-6 col-md-4">
                <div class="item-card-box" 
                     id="card-<%= item.name %>" 
                     onclick="handleItemClick('<%= item.name %>', <%= item.pricePerDay %>, <%= item.availableQuantity %>)">
                  
                  <div class="item-icon-wrapper mb-2">
                    <i class="bi bi-box-seam" style="font-size: 2rem; color: var(--maroon);"></i>
                  </div>
                  <div class="fw-bold"><%= item.displayName %></div>
                  <div class="text-muted small">₱<%= item.pricePerDay %> / day</div>
                  <div class="stock-badge <%= item.availableQuantity > 0 ? 'text-success' : 'text-danger' %>">
                    <%= item.availableQuantity %> available
                  </div>

                  <div class="qty-control-wrapper mt-2" id="qty-wrapper-<%= item.name %>" style="display:none;" onclick="event.stopPropagation()">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="updateQty('<%= item.name %>', -1)">-</button>
                      <span id="qty-display-<%= item.name %>" class="fw-bold">1</span>
                      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="updateQty('<%= item.name %>', 1)">+</button>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <div class="jm-card mb-4 p-4 shadow-sm" style="background: white; border-radius: 15px;">
          <h5 class="mb-4" style="color: var(--maroon); font-weight: 700;">
            <i class="bi bi-2-circle-fill me-2"></i>Step 2 — Rental Dates
          </h5>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label small fw-bold text-uppercase">Start Date</label>
              <input type="date" name="rentalStartDate" id="startDate" class="form-control" required onchange="updateSummary()">
            </div>
            <div class="col-md-6">
              <label class="form-label small fw-bold text-uppercase">End Date</label>
              <input type="date" name="rentalEndDate" id="endDate" class="form-control" required onchange="updateSummary()">
            </div>
          </div>
        </div>

        <div class="jm-card p-4 shadow-sm" style="background: white; border-radius: 15px;">
          <h5 class="mb-4" style="color: var(--maroon); font-weight: 700;">
            <i class="bi bi-3-circle-fill me-2"></i>Step 3 — Delivery Address
          </h5>
          <textarea name="deliveryAddress" class="form-control" rows="3" placeholder="Enter full delivery address..." required></textarea>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="summary-card p-4 shadow-sm" style="background: white; border-radius: 15px; position: sticky; top: 20px; border-top: 5px solid var(--maroon);">
          <h5 class="mb-3 fw-bold">Cost Summary</h5>
          
          <div id="summaryList" class="mb-3">
            <p class="text-muted text-center py-3">No items selected.</p>
          </div>

          <hr>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Duration:</span>
            <span id="summaryDuration" class="fw-bold">0 day(s)</span>
          </div>
          <div class="d-flex justify-content-between mb-4">
            <span class="fs-5 fw-bold">Total:</span>
            <span id="summaryTotal" class="fs-5 fw-bold text-maroon" style="color: #7c1c2e;">₱0.00</span>
          </div>

          <button type="submit" id="submitBtn" class="btn btn-maroon w-100 py-2 fw-bold" disabled style="background: #7c1c2e; color: white; border: none;">
            <i class="bi bi-send-fill me-2"></i>Submit Rental Request
          </button>
          
          <a href="/user/rentals" class="btn btn-outline-secondary w-100 mt-2 small">Back to My Rentals</a>
        </div>
      </div>
    </div>
  </form>
</div>

<style>
  :root { --maroon: #7c1c2e; }
  .item-card-box { border: 2px solid #f0f0f0; border-radius: 12px; padding: 1.5rem 1rem; text-align: center; cursor: pointer; transition: 0.2s; background: #fff; }
  .item-card-box:hover { border-color: var(--maroon); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
  .item-card-box.selected { border-color: var(--maroon); background-color: #fdf2f4; }
  .stock-badge { font-size: 0.75rem; font-weight: 600; margin-top: 5px; }
  .btn-maroon:disabled { background: #ccc !important; cursor: not-allowed; }
</style>

<script>
  // State management
  const selectedItems = new Map();

  function handleItemClick(name, price, max) {
    const card = document.getElementById(`card-${name}`);
    const qtyWrapper = document.getElementById(`qty-wrapper-${name}`);

    if (selectedItems.has(name)) {
      // De-select
      selectedItems.delete(name);
      card.classList.remove('selected');
      qtyWrapper.style.display = 'none';
    } else {
      // Select
      selectedItems.set(name, { price, qty: 1, max });
      card.classList.add('selected');
      qtyWrapper.style.display = 'block';
    }
    updateSummary();
  }

  function updateQty(name, delta) {
    const item = selectedItems.get(name);
    if (!item) return;

    const newQty = item.qty + delta;
    if (newQty >= 1 && newQty <= item.max) {
      item.qty = newQty;
      document.getElementById(`qty-display-${name}`).innerText = newQty;
      updateSummary();
    }
  }

  function updateSummary() {
    const listDiv = document.getElementById('summaryList');
    const totalSpan = document.getElementById('summaryTotal');
    const durationSpan = document.getElementById('summaryDuration');
    const submitBtn = document.getElementById('submitBtn');

    // Calculate Days
    const start = document.getElementById('startDate').value;
    const end = document.getElementById('endDate').value;
    let days = 0;
    if (start && end) {
      const diff = new Date(end) - new Date(start);
      days = Math.max(0, Math.ceil(diff / (1000 * 60 * 60 * 24)) + 1);
    }

    // Build Summary HTML
    let html = '';
    let grandTotal = 0;

    selectedItems.forEach((data, name) => {
      const itemTotal = data.price * data.qty * (days || 1);
      grandTotal += (data.price * data.qty * (days || 0)); // Only add to total if days > 0
      html += `
        <div class="d-flex justify-content-between small mb-1">
          <span>${name} x ${data.qty}</span>
          <span>₱${itemTotal.toLocaleString()}</span>
        </div>`;
    });

    listDiv.innerHTML = html || '<p class="text-muted text-center py-3">No items selected.</p>';
    durationSpan.innerText = `${days} day(s)`;
    totalSpan.innerText = `₱${grandTotal.toLocaleString(undefined, {minimumFractionDigits: 2})}`;

    // Enable button only if conditions are met
    submitBtn.disabled = !(selectedItems.size > 0 && days > 0);
  }

  // FINAL STEP: Form Submission Payload
  document.getElementById('rentalForm').onsubmit = function(e) {
    const container = document.getElementById('hiddenInputsContainer');
    container.innerHTML = ''; // Clear existing

    let index = 0;
    selectedItems.forEach((data, name) => {
      // Item Type Input
      const inputType = document.createElement('input');
      inputType.type = 'hidden';
      inputType.name = `items[${index}][itemType]`;
      inputType.value = name;
      container.appendChild(inputType);

      // Quantity Input
      const inputQty = document.createElement('input');
      inputQty.type = 'hidden';
      inputQty.name = `items[${index}][quantity]`;
      inputQty.value = data.qty;
      container.appendChild(inputQty);

      index++;
    });

    return true; // Allow form to submit
  };
</script>