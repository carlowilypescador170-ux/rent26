<% layout('layouts/boilerplate') %>
<% pageTitle = 'Login' %>

<style>
  .auth-page {
    min-height: calc(100vh - 62px);
    display: flex; align-items: center;
    background: linear-gradient(135deg, var(--maroon-dk) 0%, var(--maroon) 100%);
    padding: 40px 16px;
    position: relative; overflow: hidden;
  }
  .auth-page::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(201,150,58,0.12) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.04) 0%, transparent 40%);
  }
  .auth-card {
    background: white; border-radius: 20px;
    padding: 44px 40px; width: 100%; max-width: 440px; margin: 0 auto;
    box-shadow: 0 24px 64px rgba(0,0,0,0.3);
    position: relative; z-index: 1;
    animation: fadeInUp 0.5s ease both;
  }
  .auth-logo { text-align: center; margin-bottom: 28px; }
  .auth-logo img { width: 52px; height: 52px; object-fit: contain; margin-block: 10px; border-radius: 50%; background: white;; }
  .auth-logo h4 { font-family: 'Playfair Display', serif; color: var(--maroon); font-size: 22px; margin: 0; }
  .auth-logo span { font-size: 13px; color: var(--text-muted); }
  .auth-divider { border: none; border-top: 1.5px solid var(--border-lt); margin: 24px 0; }
  @keyframes fadeInUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
</style>

<div class="auth-page">
  <div class="container">
    <div class="auth-card">
      <div class="auth-logo">
        <img src="/images/logo.jpg" alt="J&M Rentals" />
        <h4>J&M <span style="color:var(--gold);">Rentals</span></h4>
        <span>Sign in to your account</span>
      </div>

      <form action="/auth/login" method="POST" novalidate>
        <div class="mb-3">
          <label class="form-label">Username or Email</label>
          <div class="input-group">
            <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-person"></i></span>
            <input type="text" name="login" class="form-control" placeholder="Enter username or email" required autocomplete="username" />
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label">Password</label>
          <div class="input-group">
            <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-lock"></i></span>
            <input type="password" name="password" id="passwordInput" class="form-control" placeholder="Enter password" required autocomplete="current-password" />
            <button type="button" class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);cursor:pointer;" onclick="togglePassword()">
              <i class="bi bi-eye" id="eyeIcon" style="color:var(--maroon);"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-maroon w-100 py-2" style="font-size:15px;">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
      </form>

      <hr class="auth-divider" />
      <p class="text-center mb-0" style="font-size:14px;color:var(--text-muted);">
        Don't have an account?
        <a href="/auth/register" style="color:var(--maroon);font-weight:700;">Register here</a>
      </p>
    </div>
  </div>
</div>

<% extraScripts = `
<script>
  function togglePassword() {
    const input = document.getElementById('passwordInput');
    const icon  = document.getElementById('eyeIcon');
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      input.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  }
</script>
` %>
