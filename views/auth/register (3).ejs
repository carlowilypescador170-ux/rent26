<% layout('layouts/boilerplate') %>
<% pageTitle = 'Register' %>

<style>
  .auth-page {
    min-height: calc(100vh - 62px);
    background: linear-gradient(135deg, var(--maroon-dk) 0%, var(--maroon) 100%);
    padding: 40px 16px; position: relative; overflow: hidden;
  }
  .auth-page::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 50%, rgba(201,150,58,0.1) 0%, transparent 55%);
  }
  .auth-card {
    background: white; border-radius: 20px;
    padding: 40px; width: 100%; max-width: 560px; margin: 0 auto;
    box-shadow: 0 24px 64px rgba(0,0,0,0.3);
    position: relative; z-index: 1;
    animation: fadeInUp 0.5s ease both;
  }
  .auth-logo { text-align: center; margin-bottom: 24px; }
  .auth-logo img { width: 46px; object-fit: contain; margin-bottom: 8px; }
  .auth-logo h4 { font-family: 'Playfair Display', serif; color: var(--maroon); font-size: 20px; margin: 0; }
  .step-indicators { display: flex; gap: 6px; justify-content: center; margin-bottom: 28px; }
  .step-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: var(--transition); }
  .step-dot.active { background: var(--maroon); width: 24px; border-radius: 4px; }
  .password-strength { height: 4px; border-radius: 2px; margin-top: 6px; transition: all 0.3s; }
  @keyframes fadeInUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }

  /* ── Validation States ───────────────────────────────────────────── */
  .field-wrap { position: relative; }

  /* Valid state — green border + check icon */
  .field-wrap.is-valid .form-control,
  .field-wrap.is-valid .input-group .form-control {
    border-color: #38A169 !important;
    box-shadow: 0 0 0 3px rgba(56,161,105,0.12) !important;
  }
  .field-wrap.is-valid .input-group { border-radius: 8px; box-shadow: 0 0 0 3px rgba(56,161,105,0.12); }
  .field-wrap.is-valid .vicon { color: #38A169; display: flex; }

  /* Invalid state — red border */
  .field-wrap.is-invalid .form-control,
  .field-wrap.is-invalid .input-group .form-control {
    border-color: #E53E3E !important;
    box-shadow: 0 0 0 3px rgba(229,62,62,0.12) !important;
  }
  .field-wrap.is-invalid .input-group { border-radius: 8px; box-shadow: 0 0 0 3px rgba(229,62,62,0.12); }
  .field-wrap.is-invalid .vicon { color: #E53E3E; display: flex; }

  /* Validation icon (top-right of field) */
  .vicon {
    position: absolute;
    right: 12px; top: 50%;
    transform: translateY(-50%);
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    pointer-events: none;
    z-index: 10;
  }
  /* Shift icon left when field has eye-toggle button */
  .has-toggle .vicon { right: 48px; }

  /* Feedback message below field */
  .field-msg {
    font-size: 11.5px;
    margin-top: 4px;
    min-height: 17px;
    display: block;
    transition: color 0.2s;
  }
  .field-msg.ok  { color: #38A169; }
  .field-msg.err { color: #E53E3E; }
  .field-msg.hint { color: var(--text-muted); }

  /* Shake animation for invalid submit */
  @keyframes shake {
    0%,100% { transform: translateX(0); }
    20%      { transform: translateX(-6px); }
    40%      { transform: translateX(6px); }
    60%      { transform: translateX(-4px); }
    80%      { transform: translateX(4px); }
  }
  .shake { animation: shake 0.4s ease; }

  /* Submit button disabled look */
  #submitBtn:disabled { opacity: 0.6; cursor: not-allowed; }

  /* Input group styling override for validation border */
  .input-group .form-control:focus { z-index: 3; }
</style>

<div class="auth-page py-4">
  <div class="container">
    <div class="auth-card">
      <div class="auth-logo">
        <img src="/images/logo.jpg" alt="J&M Rentals" />
        <h4>Join J&M <span style="color:var(--gold);">Rentals</span></h4>
        <span style="font-size:13px;color:var(--text-muted);">Create your free customer account</span>
      </div>

      <form action="/auth/register" method="POST" novalidate id="registerForm">
        <div class="row g-3">

          <!-- Full Name -->
          <div class="col-12">
            <label class="form-label">Full Name <span class="text-danger">*</span></label>
            <div class="field-wrap" id="wrap-fullName">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-person-fill"></i></span>
                <input type="text" name="fullName" id="fullName" class="form-control"
                  placeholder="e.g. Juan Dela Cruz"
                  value="<%= typeof formData !== 'undefined' ? formData.fullName || '' : '' %>"
                  required minlength="3" autocomplete="name"
                  
                   />
              </div>
              <span class="vicon" id="vi-fullName"><i class="bi bi-check-circle-fill" id="vic-fullName"></i></span>
              <span class="field-msg hint" id="msg-fullName">Letters only. First and last name required.</span>
            </div>
          </div>

          <!-- Username -->
          <div class="col-md-6">
            <label class="form-label">Username <span class="text-danger">*</span></label>
            <div class="field-wrap" id="wrap-username">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);">@</span>
                <input type="text" name="username" id="username" class="form-control"
                  placeholder="e.g. juandelacruz"
                  value="<%= typeof formData !== 'undefined' ? formData.username || '' : '' %>"
                  required minlength="3" maxlength="30" pattern="[a-zA-Z0-9_]+"
                  autocomplete="username"
                  
                   />
              </div>
              <span class="vicon" id="vi-username"><i class="bi bi-check-circle-fill" id="vic-username"></i></span>
              <span class="field-msg hint" id="msg-username">3–30 chars. Letters, numbers, underscores only.</span>
            </div>
          </div>

          <!-- Phone -->
          <div class="col-md-6">
            <label class="form-label">Phone Number <span class="text-danger">*</span></label>
            <div class="field-wrap" id="wrap-phoneNumber">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-telephone-fill"></i></span>
                <input type="tel" name="phoneNumber" id="phoneNumber" class="form-control"
                  placeholder="09XXXXXXXXX (11 digits)"
                  value="<%= typeof formData !== 'undefined' ? formData.phoneNumber || '' : '' %>"
                  required pattern="^(\+63|0)(9\d{9})$"
                  maxlength="11"
                  autocomplete="tel"
                  
                   />
              </div>
              <span class="vicon" id="vi-phoneNumber"><i class="bi bi-check-circle-fill" id="vic-phoneNumber"></i></span>
              <span class="field-msg hint" id="msg-phoneNumber">Numbers only, exactly 11 digits starting with 09.</span>
            </div>
          </div>

          <!-- Email -->
          <div class="col-12">
            <label class="form-label">Email Address <span class="text-danger">*</span></label>
            <div class="field-wrap" id="wrap-email">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-envelope-fill"></i></span>
                <input type="email" name="email" id="email" class="form-control"
                  placeholder="you@example.com"
                  value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
                  required autocomplete="email"
                  
                   />
              </div>
              <span class="vicon" id="vi-email"><i class="bi bi-check-circle-fill" id="vic-email"></i></span>
              <span class="field-msg hint" id="msg-email">We'll send your booking updates here.</span>
            </div>
          </div>

          <!-- Location -->
          <div class="col-12">
            <label class="form-label">Address / Location <span class="text-danger">*</span></label>
            <div class="field-wrap" id="wrap-location">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-geo-alt-fill"></i></span>
                <input type="text" name="location" id="location" class="form-control"
                  placeholder="Street, Barangay, City, Province"
                  value="<%= typeof formData !== 'undefined' ? formData.location || '' : '' %>"
                  required maxlength="255"
                  autocomplete="street-address"
                  
                   />
              </div>
              <span class="vicon" id="vi-location"><i class="bi bi-check-circle-fill" id="vic-location"></i></span>
              <span class="field-msg hint" id="msg-location">Used as default delivery address for your rentals.</span>
            </div>
          </div>

          <!-- Password -->
          <div class="col-md-6">
            <label class="form-label">Password <span class="text-danger">*</span></label>
            <div class="field-wrap has-toggle" id="wrap-password">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-lock-fill"></i></span>
                <input type="password" name="password" id="passwordField" class="form-control"
                  placeholder="Min. 8 characters"
                  required minlength="8"
                  autocomplete="new-password" />
                <button type="button" class="input-group-text"
                  style="background:var(--maroon-pale);border-color:var(--border);cursor:pointer;"
                  onclick="togglePass('passwordField','eye1')">
                  <i class="bi bi-eye" id="eye1" style="color:var(--maroon);"></i>
                </button>
              </div>
              <span class="vicon" id="vi-password"><i class="bi bi-check-circle-fill" id="vic-password"></i></span>
              <div class="password-strength" id="strengthBar" style="background:var(--border); width:0%;"></div>
              <span class="field-msg hint" id="strengthText"></span>
              <!-- Password rules checklist -->
              <div id="passwordRules" style="margin-top:8px;padding:10px 12px;background:var(--maroon-pale);border-radius:8px;border:1px solid var(--border-lt);display:none;">
                <div style="font-size:11px;font-weight:700;color:var(--maroon);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Password must have:</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 12px;">
                  <div id="rule-len" style="font-size:11.5px;display:flex;align-items:center;gap:3px;"></div>
                  <div id="rule-up"  style="font-size:11.5px;display:flex;align-items:center;gap:3px;"></div>
                  <div id="rule-lo"  style="font-size:11.5px;display:flex;align-items:center;gap:3px;"></div>
                  <div id="rule-num" style="font-size:11.5px;display:flex;align-items:center;gap:3px;"></div>
                  <div id="rule-sym" style="font-size:11.5px;display:flex;align-items:center;gap:3px;"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Confirm Password -->
          <div class="col-md-6">
            <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
            <div class="field-wrap has-toggle" id="wrap-confirm">
              <div class="input-group">
                <span class="input-group-text" style="background:var(--maroon-pale);border-color:var(--border);color:var(--maroon);"><i class="bi bi-lock-fill"></i></span>
                <input type="password" name="confirmPassword" id="confirmField" class="form-control"
                  placeholder="Repeat password"
                  required minlength="8"
                  autocomplete="new-password"
                  
                   />
                <button type="button" class="input-group-text"
                  style="background:var(--maroon-pale);border-color:var(--border);cursor:pointer;"
                  onclick="togglePass('confirmField','eye2')">
                  <i class="bi bi-eye" id="eye2" style="color:var(--maroon);"></i>
                </button>
              </div>
              <span class="vicon" id="vi-confirm"><i class="bi bi-check-circle-fill" id="vic-confirm"></i></span>
              <span class="field-msg hint" id="msg-confirm">Re-enter your password to confirm.</span>
            </div>
          </div>

        </div><!-- /row -->

        <div class="mt-4 p-3 rounded-3" style="background:var(--maroon-pale);border:1px solid var(--border-lt);font-size:12px;color:var(--text-muted);">
          <i class="bi bi-shield-check me-1" style="color:var(--maroon);"></i>
          By registering, you agree that your personal information will be used to process rental requests.
        </div>

        <button type="submit" id="submitBtn" class="btn btn-maroon w-100 mt-3 py-2" style="font-size:15px;">
          <i class="bi bi-person-check me-2"></i>Create Account
        </button>

        <!-- Overall form hint shown on bad submit -->
        <div id="formErr" style="display:none;text-align:center;font-size:12.5px;color:#E53E3E;margin-top:10px;">
          <i class="bi bi-exclamation-triangle me-1"></i>Please fix the highlighted fields above.
        </div>
      </form>

      <p class="text-center mt-3 mb-0" style="font-size:14px;color:var(--text-muted);">
        Already have an account?
        <a href="/auth/login" style="color:var(--maroon);font-weight:700;">Sign in here</a>
      </p>
    </div>
  </div>
</div>

<% extraScripts = `
<script>
(function () {
  'use strict';

  // ── STATE HELPERS ──────────────────────────────────────────────────────────
  function ok(wrapId, msgId, message) {
    const w = document.getElementById(wrapId);
    const m = document.getElementById(msgId);
    w.classList.remove('is-invalid'); w.classList.add('is-valid');
    const vi = w.querySelector('.vicon i');
    if (vi) vi.className = 'bi bi-check-circle-fill';
    m.className = 'field-msg ok';
    m.textContent = message;
  }
  function bad(wrapId, msgId, message) {
    const w = document.getElementById(wrapId);
    const m = document.getElementById(msgId);
    w.classList.remove('is-valid'); w.classList.add('is-invalid');
    const vi = w.querySelector('.vicon i');
    if (vi) vi.className = 'bi bi-x-circle-fill';
    m.className = 'field-msg err';
    m.textContent = message;
  }
  function neutral(wrapId, msgId, message) {
    const w = document.getElementById(wrapId);
    const m = document.getElementById(msgId);
    w.classList.remove('is-valid','is-invalid');
    m.className = 'field-msg hint';
    m.textContent = message;
  }

  // ── FULL NAME ──────────────────────────────────────────────────────────────
  // RULE: letters and spaces ONLY — numbers/symbols blocked as you type
  function validateFullName(force) {
    const el = document.getElementById('fullName');
    // Strip non-letter, non-space characters in real time
    el.value = el.value.replace(/[^a-zA-ZÀ-ÿ ]/g, '');
    const val = el.value.trim();

    if (!val) return force ? bad('wrap-fullName','msg-fullName','Full name is required.') : void 0;
    if (val.length < 3)    return bad('wrap-fullName','msg-fullName','Name must be at least 3 characters.');
    if (val.split(/\s+/).filter(Boolean).length < 2)
                           return bad('wrap-fullName','msg-fullName','Enter both first and last name.');
    ok('wrap-fullName','msg-fullName','✓ Looks good!');
  }

  // ── USERNAME ───────────────────────────────────────────────────────────────
  // RULE: letters/numbers/underscores, must start with letter, 3–30 chars
  function validateUsername(force) {
    const val = document.getElementById('username').value.trim();
    if (!val) return force ? bad('wrap-username','msg-username','Username is required.') : void 0;
    if (val.length < 3)             return bad('wrap-username','msg-username','At least 3 characters required.');
    if (val.length > 30)            return bad('wrap-username','msg-username','Maximum 30 characters allowed.');
    if (!/^[a-zA-Z]/.test(val))    return bad('wrap-username','msg-username','Must start with a letter.');
    if (!/^[a-zA-Z0-9_]+$/.test(val)) return bad('wrap-username','msg-username','Letters, numbers, and underscores only.');
    ok('wrap-username','msg-username','✓ @' + val);
  }

  // ── PHONE ──────────────────────────────────────────────────────────────────
  // RULE: digits ONLY, exactly 11 digits, must start with 09
  function validatePhone(force) {
    const el = document.getElementById('phoneNumber');
    // Strip non-digits and cap at 11 characters as user types
    el.value = el.value.replace(/\D/g, '').slice(0, 11);
    const val = el.value;

    if (!val) return force ? bad('wrap-phoneNumber','msg-phoneNumber','Phone number is required.') : void 0;
    if (val.length < 11) return bad('wrap-phoneNumber','msg-phoneNumber', val.length + '/11 digits — keep typing.');
    if (!val.startsWith('09')) return bad('wrap-phoneNumber','msg-phoneNumber','Must start with 09 (e.g. 09XXXXXXXXX).');
    ok('wrap-phoneNumber','msg-phoneNumber','✓ Valid phone number.');
  }

  // ── EMAIL ──────────────────────────────────────────────────────────────────
  function validateEmail(force) {
    const val = document.getElementById('email').value.trim();
    if (!val) return force ? bad('wrap-email','msg-email','Email is required.') : void 0;
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(val))
      return bad('wrap-email','msg-email','Enter a valid email (e.g. you@example.com).');
    ok('wrap-email','msg-email','✓ Valid email address.');
  }

  // ── LOCATION ───────────────────────────────────────────────────────────────
  function validateLocation(force) {
    const val = document.getElementById('location').value.trim();
    if (!val)           return force ? bad('wrap-location','msg-location','Address is required.') : void 0;
    if (val.length < 10) return bad('wrap-location','msg-location','Please enter a more complete address.');
    if (val.length > 255) return bad('wrap-location','msg-location','Address too long (max 255 chars).');
    ok('wrap-location','msg-location','✓ Address saved.');
  }

  // ── PASSWORD ───────────────────────────────────────────────────────────────
  // REQUIRED rules: 8+ chars, 1 uppercase, 1 lowercase, 1 number
  // OPTIONAL: 1 symbol (boosts strength bar only)
  const RULES = [
    { id:'rule-len', test: v => v.length >= 8,           label:'At least 8 characters',      required: true  },
    { id:'rule-up',  test: v => /[A-Z]/.test(v),         label:'One uppercase letter (A–Z)', required: true  },
    { id:'rule-lo',  test: v => /[a-z]/.test(v),         label:'One lowercase letter (a–z)', required: true  },
    { id:'rule-num', test: v => /[0-9]/.test(v),         label:'One number (0–9)',            required: true  },
    { id:'rule-sym', test: v => /[^a-zA-Z0-9]/.test(v), label:'One symbol  (!@#\$%^&*...)',  required: false },
  ];

  function checkStrength(val) {
    const bar  = document.getElementById('strengthBar');
    const lbl  = document.getElementById('strengthText');
    if (!val) { bar.style.width='0'; bar.style.background='var(--border)'; lbl.textContent=''; return; }

    let passed = 0;
    RULES.forEach(r => {
      const met = r.test(val);
      if (met) passed++;
      const el = document.getElementById(r.id);
      if (!el) return;
      el.innerHTML =
        '<i class="bi bi-' + (met ? 'check-circle-fill' : 'circle') +
        '" style="font-size:11px;margin-right:4px;color:' + (met ? '#38A169' : '#CBD5E0') + ';"></i>' +
        '<span style="color:' + (met ? '#38A169' : 'var(--text-muted)') + ';">' +
        r.label + (r.required ? '' : ' <em style=\'font-size:10px;\'>(optional)</em>') + '</span>';
    });

    const LEVELS = [
      { w:'20%', c:'#E53E3E', t:'Very Weak'  },
      { w:'40%', c:'#DD6B20', t:'Weak'       },
      { w:'60%', c:'#D69E2E', t:'Fair'       },
      { w:'80%', c:'#68D391', t:'Good'       },
      { w:'100%',c:'#38A169', t:'Strong ✓'  },
    ];
    const lv = LEVELS[passed - 1] || LEVELS[0];
    bar.style.width = lv.w; bar.style.background = lv.c;
    lbl.textContent = lv.t; lbl.style.color = lv.c;
    lbl.className = 'field-msg ' + (passed >= 4 ? 'ok' : passed >= 2 ? 'hint' : 'err');
  }

  function validatePassword(force) {
    const val = document.getElementById('passwordField').value;
    checkStrength(val);
    if (!val) {
      if (force) bad('wrap-password','strengthText','Password is required.');
      return;
    }
    // Required rules: first 4 (index 0-3)
    const reqMet = RULES.filter(r => r.required).every(r => r.test(val));
    if (reqMet) ok('wrap-password','strengthText','');
    else        bad('wrap-password','strengthText','Meet all 4 required rules above.');
    validateConfirm(); // keep confirm in sync
  }

  // ── CONFIRM PASSWORD ───────────────────────────────────────────────────────
  function validateConfirm(force) {
    const pwd = document.getElementById('passwordField').value;
    const val = document.getElementById('confirmField').value;
    if (!val) {
      if (force) return bad('wrap-confirm','msg-confirm','Please confirm your password.');
      return neutral('wrap-confirm','msg-confirm','Re-enter your password to confirm.');
    }
    if (val === pwd) ok ('wrap-confirm','msg-confirm','✓ Passwords match.');
    else             bad('wrap-confirm','msg-confirm','✗ Passwords do not match.');
  }

  // ── TOGGLE VISIBILITY ──────────────────────────────────────────────────────
  function togglePass(id, iconId) {
    const input = document.getElementById(id);
    const icon  = document.getElementById(iconId);
    input.type = input.type === 'password' ? 'text' : 'password';
    icon.classList.toggle('bi-eye');
    icon.classList.toggle('bi-eye-slash');
  }
  window.togglePass = togglePass; // expose for inline onclick

  // ── FORM SUBMIT ────────────────────────────────────────────────────────────
  function handleSubmit(e) {
    validateFullName(true);
    validateUsername(true);
    validatePhone(true);
    validateEmail(true);
    validateLocation(true);
    validatePassword(true);
    validateConfirm(true);

    const invalid = document.querySelectorAll('.field-wrap.is-invalid');
    if (!invalid.length) {
      document.getElementById('formErr').style.display = 'none';
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creating account...';
      return; // let form submit
    }

    e.preventDefault();
    document.getElementById('formErr').style.display = 'block';
    const card = document.querySelector('.auth-card');
    card.classList.remove('shake');
    void card.offsetWidth;
    card.classList.add('shake');
    invalid[0].scrollIntoView({ behavior:'smooth', block:'center' });
    const inp = invalid[0].querySelector('input');
    if (inp) setTimeout(() => inp.focus(), 300);
  }

  // ── BIND ALL EVENTS ────────────────────────────────────────────────────────
  // Script runs at bottom of body — DOM is already ready, no DOMContentLoaded needed
  (function bindEvents() {
    const $ = id => document.getElementById(id);

    // ── Full Name: block digits and symbols at keydown level ──────────────────
    $('fullName').addEventListener('keydown', function(e) {
      // Allow: backspace, delete, arrows, tab, home, end
      const control = [8,9,13,16,17,18,20,27,35,36,37,38,39,40,45,46];
      if (control.includes(e.keyCode)) return;
      // Allow: Ctrl+A/C/V/X/Z
      if (e.ctrlKey || e.metaKey) return;
      // Block anything that's not a letter or space
      if (!/^[a-zA-ZÀ-ÿ ]$/.test(e.key)) e.preventDefault();
    });
    $('fullName').addEventListener('input',  () => validateFullName());
    $('fullName').addEventListener('blur',   () => validateFullName(true));

    // ── Phone: block non-digits and enforce max 11 at keydown level ───────────
    $('phoneNumber').addEventListener('keydown', function(e) {
      const control = [8,9,13,16,17,18,20,27,35,36,37,38,39,40,45,46];
      if (control.includes(e.keyCode)) return;
      if (e.ctrlKey || e.metaKey) return;
      // Block non-digit keys
      if (!/^[0-9]$/.test(e.key)) { e.preventDefault(); return; }
      // Block if already at 11 digits
      if (this.value.replace(/\D/g,'').length >= 11) e.preventDefault();
    });
    // Also handle paste — strip non-digits and cap
    $('phoneNumber').addEventListener('paste', function(e) {
      e.preventDefault();
      const pasted = (e.clipboardData || window.clipboardData).getData('text');
      const digits = pasted.replace(/\D/g,'').slice(0, 11);
      this.value = digits;
      validatePhone();
    });
    $('phoneNumber').addEventListener('input', () => validatePhone());
    $('phoneNumber').addEventListener('blur',  () => validatePhone(true));

    $('username').addEventListener('input',  () => validateUsername());
    $('username').addEventListener('blur',   () => validateUsername(true));

    $('email').addEventListener('input', () => validateEmail());
    $('email').addEventListener('blur',  () => validateEmail(true));

    $('location').addEventListener('input', () => validateLocation());
    $('location').addEventListener('blur',  () => validateLocation(true));

    $('passwordField').addEventListener('focus', () => {
      $('passwordRules').style.display = 'block';
      checkStrength($('passwordField').value);
    });
    $('passwordField').addEventListener('input', () => validatePassword());
    $('passwordField').addEventListener('blur',  () => validatePassword(true));

    $('confirmField').addEventListener('input', () => validateConfirm());
    $('confirmField').addEventListener('blur',  () => validateConfirm(true));

    $('registerForm').addEventListener('submit', handleSubmit);

    // Re-validate pre-filled fields (after server redirect with errors)
    ['fullName','username','phoneNumber','email','location'].forEach(id => {
      if ($(id).value) $(id).dispatchEvent(new Event('blur'));
    });
  })();

})();
</script>
